    {
      "id": "flow-detail",
      "type": "text",
      "x": 40,
      "y": 530,
      "width": 300,
      "height": 180,
      "text": "1. POST /sessions/{id}/stages/{stage}/start\n2. sessions.py creates asyncio.Task\n3. run_agent() builds system prompt\n4. Claude Agent SDK query() loop starts\n5. Claude generates Python code\n6. MCP tool execute_code called\n7. sandbox.py → Sandbox.create.aio()\n   image=debian+ML, volume=/data\n   gpu=optional, timeout=600s\n8. stdout streams → metrics.py parses\n9. broadcaster publishes SSE events\n10. Agent decides: loop or finish\n11. Post-stage: validate → S3 sync → meta",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 1,
      "opacity": 100,
      "angle": 0,
      "seed": 42,
      "version": 2,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775392149707,
      "link": null,
      "locked": false,
      "versionNonce": 423776852,
      "index": "af",
      "strokeStyle": "solid",
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. POST /sessions/{id}/stages/{stage}/start\n2. sessions.py creates asyncio.Task\n3. run_agent() builds system prompt\n4. Claude Agent SDK query() loop starts\n5. Claude generates Python code\n6. MCP tool execute_code called\n7. sandbox.py → Sandbox.create.aio()\n   image=debian+ML, volume=/data\n   gpu=optional, timeout=600s\n8. stdout streams → metrics.py parses\n9. broadcaster publishes SSE events\n10. Agent decides: loop or finish\n11. Post-stage: validate → S3 sync → meta",
      "autoResize": true,
      "lineHeight": 1.153846153846154
    },
