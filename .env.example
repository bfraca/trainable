# Anthropic API Key (required for AI agent)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Modal (required for sandboxed code execution)
# Run: modal token set

# Claude model and auth
# CLAUDE_MODEL=claude-opus-4-6
# CLAUDE_CODE_OAUTH_TOKEN=

# PostgreSQL (set by docker-compose, override for local dev)
# DATABASE_URL=postgresql+asyncpg://trainable:trainable@localhost:5432/trainable
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# S3 / MinIO (set by docker-compose, override for local dev)
# S3_ENDPOINT=http://localhost:4566
# S3_ENDPOINT_EXTERNAL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_REGION=us-east-1

# Modal sandbox
# MODAL_APP_NAME=trainable
# MODAL_VOLUME_NAME=trainable-data
# SANDBOX_TIMEOUT=600

# Agent
# AGENT_MAX_TURNS=30
# AGENT_TIMEOUT_SECONDS=1800
# AGENT_ABORT_TIMEOUT=5.0

# SSE / Broadcaster
# SSE_KEEPALIVE_SECONDS=30.0
# BROADCASTER_MAX_QUEUE_SIZE=1000

# CORS (comma-separated origins, or * for all)
# CORS_ORIGINS=["*"]

# Upload limits
# MAX_UPLOAD_SIZE_BYTES=524288000

# Data explorer
# QUERY_DEFAULT_LIMIT=100
# QUERY_MAX_LIMIT=1000
# PREVIEW_DEFAULT_LIMIT=50

# Logging
# LOG_LEVEL=INFO
